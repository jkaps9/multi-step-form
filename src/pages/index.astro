---
import { Font } from "astro:assets";
import { getImage } from "astro:assets";
import "../styles/global.scss";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <link
      rel="icon"
      href="/favicon.ico"
    />
    <meta
      name="viewport"
      content="width=device-width"
    />
    <meta
      name="generator"
      content={Astro.generator}
    />
    <title>Astro</title>
    <Font
      cssVariable="--font-ubuntu"
      preload
    />
  </head>
  <body>
    <h1 class="textpreset1">Hello</h1>
    <button class="btn btn--primary">Next Step</button>
    <button class="btn btn--secondary">Next Step</button>
    <button class="btn">Go Back</button>
    <div class="sidebar">
      <div class="bg-wrapper"></div>
    </div>
  </body>
</html>

<style lang="scss">
  body {
    font-family: var(--font-ubuntu);
  }

  .sidebar {
    align-items: flex-start;
    background-color: $colors-purple-600;
    box-sizing: content-box;
    display: flex;
    flex-shrink: 0;
    min-height: 568px;
    min-width: 50vw;
    padding: $spacing-lg $spacing-md;
    position: relative;
    z-index: -1;
    .bg-wrapper {
      background-image: url("/src/assets/images/bg-sidebar-mobile.svg");
      background-position: center bottom;
      background-repeat: no-repeat;
      background-size: contain;
      width: 100%;
      height: 100%;
      position: relative;
      z-index: 1;
    }
  }

  .textpreset1 {
    @include textpreset1;
  }

  .textpreset2 {
    @include textpreset2;
  }

  .textpreset3 {
    @include textpreset3;
  }

  .textpreset4 {
    @include textpreset4;
  }

  .textpreset4meidum {
    @include textpreset4medium;
  }

  .textpreset4regular {
    @include textpreset4regular;
  }

  .textpreset5 {
    @include textpreset5;
  }
</style>
