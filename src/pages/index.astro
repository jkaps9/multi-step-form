---
import { Font } from "astro:assets";
import { getImage } from "astro:assets";
import "../styles/global.scss";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <link
      rel="icon"
      href="/favicon.ico"
    />
    <meta
      name="viewport"
      content="width=device-width"
    />
    <meta
      name="generator"
      content={Astro.generator}
    />
    <title>Astro</title>
    <Font
      cssVariable="--font-ubuntu"
      preload
    />
  </head>
  <body>
    <!--
    <button class="btn btn--secondary">Next Step</button>
    <button class="btn">Go Back</button> -->
    <section class="form-section">
      <div class="form-section__container">
        <div class="sidebar">
          <ul class="progress-steps">
            <li class="progress-steps__item">
              <div class="step-number active">1</div>
              <div class="step-info">
                <p class="step-number-text">Step 1</p>
                <p class="step-description">Your Info</p>
              </div>
            </li>
            <li class="progress-steps__item">
              <div class="step-number">2</div>
              <div class="step-info">
                <p class="step-number-text">Step 2</p>
                <p class="step-description">Select Plan</p>
              </div>
            </li>
            <li class="progress-steps__item">
              <div class="step-number">3</div>
              <div class="step-info">
                <p class="step-number-text">Step 3</p>
                <p class="step-description">Add-Ons</p>
              </div>
            </li>
            <li class="progress-steps__item">
              <div class="step-number">4</div>
              <div class="step-info">
                <p class="step-number-text">Step 4</p>
                <p class="step-description">Summary</p>
              </div>
            </li>
          </ul>
        </div>
        <div class="form-container">
          <div class="form-header">
            <h2 class="form-header__title textpreset2">Personal info</h2>
            <p class="form-header__text textpreset3">
              Please provide your name, email address, and phone number.
            </p>
          </div>
          <form class="multi-step-form">
            <p class="form-group">
              <label for="name">Name</label>
              <input
                type="text"
                id="name"
                name="fullname"
                oninput="this.setCustomValidity('')"
                placeholder="e.g. Stephen King"
                autocomplete="name"
                required
              />
            </p>
            <p class="form-group">
              <label for="email">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                oninput="this.setCustomValidity('')"
                placeholder="e.g. stephenking@lorem.com"
                autocomplete="email"
                required
              />
            </p>
            <p class="form-group">
              <label for="phone">Phone Number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                oninput="this.setCustomValidity('')"
                placeholder="e.g. +1 234 567 890"
                autocomplete="tel"
                required
              />
            </p>
            <footer class="form-footer">
              <button class="btn btn--primary">Next Step</button>
            </footer>
          </form>
        </div>
      </div>
    </section>
  </body>
</html>

<style lang="scss">
  body {
    align-items: center;
    background-color: $colors-blue-50;
    display: flex;
    flex-direction: column;
    font-family: var(--font-ubuntu);
    min-height: 100vh;
  }

  .sidebar {
    background-image: url("/src/assets/images/bg-sidebar-mobile.svg");
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    color: $colors-white;
    display: flex;
    justify-content: center;
    min-height: 172px;
    padding-top: $spacing-md;

    .progress-steps {
      display: flex;
      gap: $spacing-xs;
      list-style-type: none;
      padding: 0;
    }

    .step-number {
      align-items: center;
      border: 1px solid $colors-white;
      border-radius: 100vh;
      display: flex;
      height: 2rem;
      justify-content: center;
      width: 2rem;

      &.active {
        background-color: $colors-blue-200;
        border-color: transparent;
        color: $colors-blue-950;
      }
    }

    .step-number,
    .step-description {
      @include textpreset4;
    }

    .step-number-text {
      @include textpreset5;
      color: $colors-blue-300;
      display: none;
    }

    .step-description {
      display: none;
    }
  }

  .form-container {
    background-color: $colors-white;
    border-radius: 10px;
    box-shadow: 0 25px 40px -20px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    gap: $spacing-sm;
    margin: -75px $spacing-xs 0;
    padding: $spacing-md $spacing-sm;
  }

  .form-header {
    display: flex;
    flex-direction: column;
    gap: $spacing-xxs;
    &__text {
      color: $colors-grey-500;
      max-width: 45ch;
    }
  }

  .multi-step-form {
    display: flex;
    flex-direction: column;
    gap: $spacing-xs;

    label {
      @include textpreset5;
      color: $colors-blue-950;
      display: block;
      margin-bottom: $spacing-xxs;
    }

    input {
      @include textpreset4medium;
      border: 1px solid $colors-purple-200;
      border-radius: 4px;
      color: $colors-grey-500;
      padding: $spacing-xxs $spacing-xs;
      width: stretch;

      &::placeholder {
        color: inherit;
      }

      &:focus-visible {
        outline-color: $colors-purple-600;
      }

      &:hover {
        border-color: $colors-purple-400;
      }
    }

    .form-group:has(input:user-invalid),
    .form-group:has(textarea:user-invalid) {
      input,
      textarea {
        border-color: $colors-red-500;
      }
    }

    .form-footer {
      align-self: flex-end;
    }
  }

  .textpreset1 {
    @include textpreset1;
  }

  .textpreset2 {
    @include textpreset2;
  }

  .textpreset3 {
    @include textpreset3;
  }

  .textpreset4 {
    @include textpreset4;
  }

  .textpreset4meidum {
    @include textpreset4medium;
  }

  .textpreset4regular {
    @include textpreset4regular;
  }

  .textpreset5 {
    @include textpreset5;
  }

  @media (min-width: 0rem) and (max-width: 47.975rem) {
    .multi-step-form {
      .form-footer {
        background-color: $colors-white;
        bottom: 0;
        box-shadow: 0 25px 40px -20px rgba(0, 0, 0, 0.1);
        display: flex;
        justify-content: flex-end;
        padding: $spacing-xs;
        position: fixed;
        right: 0;
        width: stretch;
      }
    }
  }

  @media (min-width: 48rem) {
    body {
      justify-content: center;
    }

    .form-section {
      justify-content: center;
      display: flex;
      &__container {
        background-color: $colors-white;
        border-radius: 16px;
        box-shadow: 0 25px 40px -20px rgba(0, 0, 0, 0.1);
        display: flex;
        padding: $spacing-xs;
        gap: clamp(2.625rem, -0.375rem + 6.25vw, 5.25rem);
      }
    }

    .form-container {
      background-color: transparent;
      gap: $spacing-md;
      margin: 0;
      box-shadow: none;
    }

    .form-header {
      &__title {
        @include textpreset1;
      }
    }

    .multi-step-form {
      gap: $spacing-sm;
      height: stretch;

      label {
        @include textpreset4;
      }

      input {
        @include textpreset3medium;
        min-height: 3rem;
      }

      .form-footer {
        align-items: flex-end;
        display: flex;
        flex: 1;
      }
    }

    .sidebar {
      justify-content: flex-start;
      background-image: url("/src/assets/images/bg-sidebar-desktop.svg");
      background-position: bottom;
      background-repeat: no-repeat;
      background-size: cover;
      border-radius: 1rem;
      display: flex;
      min-width: clamp(12.875rem, 8.0179rem + 10.119vw, 17.125rem);
      min-height: 568px;
      padding: $spacing-lg clamp($spacing-sm, 0.8571rem + 2.381vw, $spacing-lg);

      .progress-steps {
        display: flex;
        flex-direction: column;
        gap: $spacing-md;
        list-style-type: none;
        padding: 0;
        text-transform: uppercase;

        &__item {
          align-items: center;
          display: flex;
          gap: $spacing-xs;
        }
      }

      .step-number-text {
        display: block;
      }

      .step-description {
        display: block;
      }
    }
  }

  @media (min-width: 64rem) {
    .form-section {
      width: stretch;
      &__container {
        max-width: 940px;
        width: stretch;
      }
    }
    .form-header {
      &__text {
        max-width: 65ch;
        text-wrap: nowrap;
      }
    }
  }
</style>
